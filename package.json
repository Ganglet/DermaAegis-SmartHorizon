{
  "name": "dermaegis-unified",
  "version": "2.0.0",
  "description": "Unified Skin Lesion Intelligence Workspace with Monte Carlo Dropout, Grad-CAM, and Fitzpatrick Bias Analysis",
  "scripts": {
    "api": "uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload",
    "ui": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run api\" \"npm run ui\"",
    "install:frontend": "cd frontend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "preview:frontend": "cd frontend && npm run preview",
    "gradio": "python app.py",
    "train": "python train.py",
    "evaluate": "python evaluate_checkpoint.py"
  },
  "keywords": [
    "dermatology",
    "skin-cancer",
    "deep-learning",
    "tensorflow",
    "fastapi",
    "react",
    "gradio",
    "monte-carlo-dropout",
    "grad-cam",
    "fitzpatrick-bias",
    "ham10000"
  ],
  "author": "DermAegis AI Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
